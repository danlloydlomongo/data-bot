APP_ENV=local
APP_DEBUG=true
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=${DB_DATABASE:-data_bot}
DB_USERNAME=${DB_USERNAME:-root}
DB_PASSWORD=${DB_PASSWORD:-secret}
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_CONNECTION=redis
MONGODB_URI=mongodb://${MONGO_USERNAME:-root}:${MONGO_PASSWORD:-secret}@mongodb:27017
MONGODB_DATABASE=data_bot_docs

